# Required for all attacks and evaluation (OpenRouter)
OPENROUTER_API_KEY=sk-or-REPLACE-ME

# Optional: only for visual_object_replacement/visual_text_replacement data generation (REVE)
REVE_API_KEY=reve-REPLACE-ME

# Optional: only for Ollama-based inference (alternative to OpenRouter)
OLLAMA_API_KEY=REPLACE-ME

# Optional: only for HuggingFace model downloads
HUGGINGFACE_KEY=hf_REPLACE-ME
